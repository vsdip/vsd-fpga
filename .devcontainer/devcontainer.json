{
  "name": "VSD FPGA Fabric Workshop",
  "image": "ghcr.io/vsdip/vsd-fpga-codespace:latest",

  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "mshr-h.veriloghdl",
        "ms-python.python",
        "ms-vscode.cpptools",
        "eamodio.gitlens"
      ]
    }
  },

  "postCreateCommand": "bash .devcontainer/setup-vsd-fpga.sh",

  "remoteUser": "vscode"
}
